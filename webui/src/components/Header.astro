---
const { currentChunk, searchData } = Astro.props;

// Get commit SHA and repo URL from environment variables (set during CI/CD build)
const commitSha = import.meta.env.PUBLIC_COMMIT_SHA;
const repoUrl = import.meta.env.PUBLIC_REPO_URL;
const shaShort = commitSha ? commitSha.substring(0, 7) : null;
const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-50 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Title -->
      <div class="flex-shrink-0">
        <a href={base} class="flex items-center gap-3 hover:opacity-80 transition-opacity">
          <span class="text-xl font-bold text-gray-900 dark:text-white">
            Танець недоумка
          </span>
          <span class="hidden sm:inline text-sm text-gray-500 dark:text-gray-400">
            / The Dance of the Fool
          </span>
        </a>
        {shaShort && repoUrl && (
          <a
            href={`${repoUrl}/commit/${commitSha}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 mt-1 px-2 py-0.5 text-xs font-mono bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
            title={`Build from commit ${shaShort}`}
          >
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
            {shaShort}
          </a>
        )}
      </div>

      <!-- Search Box -->
      {searchData && (
        <div class="flex-1 max-w-md mx-4 relative">
          <div class="relative">
            <input
              type="text"
              id="searchInput"
              placeholder="Search Ukrainian or English text..."
              class="w-full px-4 py-2 pl-10 pr-10 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              autocomplete="off"
            />
            <svg class="absolute left-3 top-2.5 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <button
              id="clearSearch"
              class="hidden absolute right-3 top-2.5 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
              aria-label="Clear search"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </button>
          </div>

          <!-- Search Results Dropdown -->
          <div
            id="searchResults"
            class="hidden absolute top-full mt-2 w-full max-h-96 overflow-y-auto bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 z-50"
          >
            <div id="searchResultsContent" class="py-2"></div>
          </div>
        </div>
      )}

      <!-- Navigation -->
      <div class="flex items-center gap-4">
        {currentChunk && (
          <div class="flex items-center gap-2">
            <a
              href={`${base}chunk/${String(currentChunk - 1).padStart(2, '0')}`}
              class={`px-3 py-1.5 rounded text-sm font-medium transition-colors ${
                currentChunk > 1
                  ? 'bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700'
                  : 'bg-gray-50 dark:bg-gray-900 text-gray-400 cursor-not-allowed'
              }`}
              aria-disabled={currentChunk <= 1}
            >
              ← Prev
            </a>

            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
              Chunk {String(currentChunk).padStart(2, '0')}
            </span>

            <a
              href={`${base}chunk/${String(currentChunk + 1).padStart(2, '0')}`}
              class={`px-3 py-1.5 rounded text-sm font-medium transition-colors ${
                currentChunk < 39
                  ? 'bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700'
                  : 'bg-gray-50 dark:bg-gray-900 text-gray-400 cursor-not-allowed'
              }`}
              aria-disabled={currentChunk >= 39}
            >
              Next →
            </a>
          </div>
        )}

        <!-- Settings dropdown -->
        <div class="relative">
          <button
            id="settingsToggle"
            class="p-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
            aria-label="Settings"
            title="Settings"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </button>

          <!-- Settings dropdown menu -->
          <div
            id="settingsMenu"
            class="hidden absolute right-0 mt-2 w-80 bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 py-2 z-50"
          >
            <div class="px-4 py-2 border-b border-gray-200 dark:border-gray-700">
              <h3 class="font-semibold text-gray-900 dark:text-white">Settings</h3>
            </div>

            <!-- View Mode -->
            <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700">
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                View Mode
              </label>
              <div class="grid grid-cols-2 gap-2">
                <a
                  href={base}
                  class="px-3 py-2 text-center text-sm rounded-md border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                >
                  📑 Chunk View
                </a>
                <a
                  href={`${base}book`}
                  class="px-3 py-2 text-center text-sm rounded-md border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                >
                  📖 Full Book
                </a>
              </div>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">
                Switch between chunked navigation or continuous reading
              </p>
            </div>

            <!-- Font Selection -->
            <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700">
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Reading Font
              </label>
              <select
                id="fontSelect"
                class="w-full px-3 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                <option value="Noto Serif">Noto Serif (Default)</option>
                <option value="PT Serif">PT Serif</option>
                <option value="Merriweather">Merriweather</option>
                <option value="Georgia">Georgia</option>
              </select>
            </div>

            <!-- Line Numbers Toggle -->
            <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700">
              <label class="flex items-center justify-between cursor-pointer">
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Line Numbers</span>
                <div class="relative">
                  <input type="checkbox" id="lineNumbersToggle" class="sr-only peer" />
                  <div class="w-11 h-6 bg-gray-300 dark:bg-gray-600 rounded-full peer-checked:bg-blue-600 transition-colors"></div>
                  <div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
                </div>
              </label>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                Show line numbers in Ukrainian text column
              </p>
            </div>

            <!-- Uncertainties Toggle -->
            <div class="px-4 py-3">
              <label class="flex items-center justify-between cursor-pointer">
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Translation Notes</span>
                <div class="relative">
                  <input type="checkbox" id="uncertaintiesToggle" class="sr-only peer" checked />
                  <div class="w-11 h-6 bg-gray-300 dark:bg-gray-600 rounded-full peer-checked:bg-blue-600 transition-colors"></div>
                  <div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
                </div>
              </label>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                Display translation uncertainties and notes
              </p>
            </div>
          </div>
        </div>

        <!-- Dark mode toggle -->
        <button
          id="darkModeToggle"
          class="p-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
          aria-label="Toggle dark mode"
          title="Toggle dark mode (D)"
        >
          <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" />
          </svg>
          <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  // Settings management
  document.addEventListener('DOMContentLoaded', () => {
    // Dark mode toggle
    const darkModeBtn = document.getElementById('darkModeToggle');
    if (darkModeBtn && typeof window.toggleDarkMode === 'function') {
      darkModeBtn.addEventListener('click', window.toggleDarkMode);
    }

    // Settings dropdown toggle
    const settingsToggle = document.getElementById('settingsToggle');
    const settingsMenu = document.getElementById('settingsMenu');

    if (settingsToggle && settingsMenu) {
      settingsToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        settingsMenu.classList.toggle('hidden');
      });

      // Close menu when clicking outside
      document.addEventListener('click', (e) => {
        if (!settingsMenu.contains(e.target as Node) && !settingsToggle.contains(e.target as Node)) {
          settingsMenu.classList.add('hidden');
        }
      });

      // Prevent menu from closing when clicking inside
      settingsMenu.addEventListener('click', (e) => {
        e.stopPropagation();
      });
    }

    // Initialize settings from localStorage
    const savedFont = localStorage.getItem('readingFont') || 'Noto Serif';
    const savedLineNumbers = localStorage.getItem('lineNumbers') === 'true';
    const savedUncertainties = localStorage.getItem('showUncertainties') !== 'false'; // default true

    // Font selection
    const fontSelect = document.getElementById('fontSelect') as HTMLSelectElement;
    if (fontSelect) {
      fontSelect.value = savedFont;
      document.documentElement.style.setProperty('--reading-font', savedFont);

      fontSelect.addEventListener('change', () => {
        const font = fontSelect.value;
        localStorage.setItem('readingFont', font);
        document.documentElement.style.setProperty('--reading-font', font);
      });
    }

    // Line numbers toggle
    const lineNumbersToggle = document.getElementById('lineNumbersToggle') as HTMLInputElement;
    if (lineNumbersToggle) {
      lineNumbersToggle.checked = savedLineNumbers;
      if (savedLineNumbers) {
        document.documentElement.classList.add('line-numbers-enabled');
      }

      lineNumbersToggle.addEventListener('change', () => {
        const enabled = lineNumbersToggle.checked;
        localStorage.setItem('lineNumbers', String(enabled));
        if (enabled) {
          document.documentElement.classList.add('line-numbers-enabled');
        } else {
          document.documentElement.classList.remove('line-numbers-enabled');
        }
      });
    }

    // Uncertainties toggle
    const uncertaintiesToggle = document.getElementById('uncertaintiesToggle') as HTMLInputElement;
    if (uncertaintiesToggle) {
      uncertaintiesToggle.checked = savedUncertainties;
      if (!savedUncertainties) {
        document.querySelectorAll('.uncertainty-panel').forEach(el => {
          (el as HTMLElement).style.display = 'none';
        });
      }

      uncertaintiesToggle.addEventListener('change', () => {
        const enabled = uncertaintiesToggle.checked;
        localStorage.setItem('showUncertainties', String(enabled));
        document.querySelectorAll('.uncertainty-panel').forEach(el => {
          (el as HTMLElement).style.display = enabled ? '' : 'none';
        });
      });
    }
  });

  // Search functionality
  if (document.getElementById('searchInput')) {
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const clearBtn = document.getElementById('clearSearch') as HTMLButtonElement;
    const searchResults = document.getElementById('searchResults') as HTMLDivElement;
    const searchResultsContent = document.getElementById('searchResultsContent') as HTMLDivElement;

    // Load search data from the page
    const searchDataEl = document.getElementById('search-data');
    const searchData = searchDataEl ? JSON.parse(searchDataEl.textContent || '[]') : [];

    let searchTimeout: number | null = null;

    // Escape HTML to prevent XSS
    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Highlight matching text in snippet
    function highlightMatch(text: string, query: string): string {
      if (!query) return escapeHtml(text);

      const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return escapeHtml(text).replace(
        new RegExp(`(${escapeHtml(query).replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi'),
        '<mark class="bg-yellow-200 dark:bg-yellow-600">$1</mark>'
      );
    }

    // Get context snippet around match
    function getSnippet(text: string, query: string, maxLength: number = 150): string {
      const lowerText = text.toLowerCase();
      const lowerQuery = query.toLowerCase();
      const matchIndex = lowerText.indexOf(lowerQuery);

      if (matchIndex === -1) return text.substring(0, maxLength) + '...';

      const start = Math.max(0, matchIndex - 50);
      const end = Math.min(text.length, matchIndex + query.length + 100);

      let snippet = text.substring(start, end);
      if (start > 0) snippet = '...' + snippet;
      if (end < text.length) snippet = snippet + '...';

      return snippet;
    }

    // Perform search
    function performSearch(query: string) {
      if (!query || query.length < 2) {
        searchResults.classList.add('hidden');
        return;
      }

      const lowerQuery = query.toLowerCase();
      const results: Array<{
        pageNumber: number;
        text: string;
        language: 'uk' | 'en';
        snippet: string;
      }> = [];

      // Determine base URL for page links (BASE_URL respects the site's base path)
      const siteBase = import.meta.env.BASE_URL;
      const currentPath = window.location.pathname;
      const isIndexPage = currentPath === siteBase || currentPath === siteBase + 'index.html';
      const pageBaseUrl = isIndexPage ? siteBase + 'book' : '';

      // Search through all pages
      searchData.forEach((page: any) => {
        // Search Ukrainian text
        if (page.ukrainian_text && page.ukrainian_text.toLowerCase().includes(lowerQuery)) {
          results.push({
            pageNumber: page.page_number,
            text: page.ukrainian_text,
            language: 'uk',
            snippet: getSnippet(page.ukrainian_text, query)
          });
        }

        // Search English text
        if (page.english_text && page.english_text.toLowerCase().includes(lowerQuery)) {
          // Only add if not already added from Ukrainian
          if (!results.find(r => r.pageNumber === page.page_number)) {
            results.push({
              pageNumber: page.page_number,
              text: page.english_text,
              language: 'en',
              snippet: getSnippet(page.english_text, query)
            });
          } else {
            // Add English match as separate result
            results.push({
              pageNumber: page.page_number,
              text: page.english_text,
              language: 'en',
              snippet: getSnippet(page.english_text, query)
            });
          }
        }
      });

      // Display results
      if (results.length === 0) {
        searchResultsContent.innerHTML = `
          <div class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
            No results found for "${escapeHtml(query)}"
          </div>
        `;
      } else {
        const maxResults = 20;
        const displayResults = results.slice(0, maxResults);

        searchResultsContent.innerHTML = `
          ${displayResults.map(result => `
            <a
              href="${pageBaseUrl}#page-${result.pageNumber}"
              class="block px-4 py-3 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors border-b border-gray-100 dark:border-gray-700 last:border-b-0"
              onclick="document.getElementById('searchResults').classList.add('hidden')"
            >
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs font-semibold text-blue-600 dark:text-blue-400">
                  Page ${result.pageNumber}
                </span>
                <span class="text-xs text-gray-500 dark:text-gray-400">
                  ${result.language === 'uk' ? '🇺🇦 Ukrainian' : '🇬🇧 English'}
                </span>
              </div>
              <div class="text-sm text-gray-700 dark:text-gray-300">
                ${highlightMatch(result.snippet, query)}
              </div>
            </a>
          `).join('')}
          ${results.length > maxResults ? `
            <div class="px-4 py-2 text-xs text-center text-gray-500 dark:text-gray-400">
              Showing ${maxResults} of ${results.length} results
            </div>
          ` : ''}
        `;
      }

      searchResults.classList.remove('hidden');
    }

    // Input event listener with debouncing
    searchInput.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value;

      // Show/hide clear button
      if (query) {
        clearBtn.classList.remove('hidden');
      } else {
        clearBtn.classList.add('hidden');
        searchResults.classList.add('hidden');
      }

      // Debounce search
      if (searchTimeout) clearTimeout(searchTimeout);
      searchTimeout = window.setTimeout(() => {
        performSearch(query);
      }, 300);
    });

    // Clear button
    clearBtn.addEventListener('click', () => {
      searchInput.value = '';
      clearBtn.classList.add('hidden');
      searchResults.classList.add('hidden');
      searchInput.focus();
    });

    // Close search results when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!searchInput.contains(target) && !searchResults.contains(target)) {
        searchResults.classList.add('hidden');
      }
    });

    // Keyboard shortcut: Ctrl+K or Cmd+K to focus search
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        searchInput.focus();
        searchInput.select();
      }

      // Escape to close search results
      if (e.key === 'Escape' && !searchResults.classList.contains('hidden')) {
        searchResults.classList.add('hidden');
        searchInput.blur();
      }
    });
  }
</script>
