---
interface Uncertainty {
  original: string;
  question: string;
  translation: string;
}

interface Props {
  uncertainties: Uncertainty[];
  pageNumber: number;
}

const { uncertainties, pageNumber } = Astro.props;

if (uncertainties.length === 0) {
  return null;
}
---

<div class="uncertainty-panel mt-4 p-4 bg-light-uncertainty dark:bg-dark-uncertainty rounded-lg border border-yellow-300 dark:border-yellow-800">
  <div class="flex items-start gap-2 mb-3">
    <svg class="w-5 h-5 text-yellow-700 dark:text-yellow-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
    </svg>
    <div class="flex-1">
      <h4 class="font-semibold text-yellow-900 dark:text-yellow-200 mb-2">
        Translation Notes (Page {pageNumber})
      </h4>

      <div class="space-y-3">
        {uncertainties.map((unc, index) => (
          <div class="text-sm">
            <div class="mb-1">
              <span class="font-medium text-yellow-900 dark:text-yellow-200">Original:</span>
              <span class="ml-2 text-yellow-800 dark:text-yellow-300">"{unc.original}"</span>
            </div>
            <div class="mb-1">
              <span class="font-medium text-yellow-900 dark:text-yellow-200">Question:</span>
              <span class="ml-2 text-yellow-800 dark:text-yellow-300">{unc.question}</span>
            </div>
            <div>
              <span class="font-medium text-yellow-900 dark:text-yellow-200">Translation:</span>
              <span class="ml-2 text-yellow-800 dark:text-yellow-300">"{unc.translation}"</span>
            </div>
            {index < uncertainties.length - 1 && (
              <div class="mt-3 border-t border-yellow-300 dark:border-yellow-700 pt-3" />
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
