---
import UncertaintyPanel from './UncertaintyPanel.astro';

interface Uncertainty {
  original: string;
  question: string;
  translation: string;
}

interface Page {
  page_number: number;
  ukrainian_text: string;
  english_text: string;
  char_count: number;
  word_count: number;
  uncertainties: Uncertainty[];
}

interface Props {
  page: Page;
  showDivider?: boolean;
}

const { page, showDivider = true } = Astro.props;

// Split Ukrainian text into lines (used for optional line numbering in parallel view)
function splitIntoLines(text: string): string[] {
  if (!text) return [];
  return text.split('\n').filter((line) => line.trim() || line === '');
}

// Minimal, safe markdown -> HTML for the English translation.
function simpleMarkdownToHtml(text: string): string {
  return text
    .replace(/^#### (.+)$/gm, '<h4>$1</h4>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .split('\n\n')
    .map((para) => (para.trim() ? `<p>${para}</p>` : ''))
    .join('\n');
}

const hasUk = Boolean(page.ukrainian_text && page.ukrainian_text.trim());
---

<article id={`page-${page.page_number}`} class="page-spread scroll-mt-24" data-page={page.page_number}>
  <!-- Subtle page marker (small; not a heading-sized banner) -->
  <div class="page-marker">
    <span class="page-marker-num">p.&nbsp;{page.page_number}</span>
    {page.uncertainties.length > 0 && (
      <span class="uncertainty-badge note-only">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
        {page.uncertainties.length}
      </span>
    )}
  </div>

  <div class="spread-grid">
    <!-- Ukrainian (original) -->
    <section class="lang-col lang-uk">
      <div class="lang-label">
        <span class="lang-chip">🇺🇦 Українська</span>
        <span class="lang-meta">{page.char_count} chars · {page.word_count} words</span>
      </div>
      <div class="ukrainian-text">
        {hasUk ? (
          splitIntoLines(page.ukrainian_text).map((line) => (
            <div class="ukrainian-text-line">{line || ' '}</div>
          ))
        ) : (
          <em class="empty-page">— no text on this page —</em>
        )}
      </div>
    </section>

    <!-- English (translation) -->
    <section class="lang-col lang-en">
      <div class="lang-label">
        <span class="lang-chip">🇬🇧 English</span>
      </div>
      <div class="english-text">
        <Fragment set:html={simpleMarkdownToHtml(page.english_text)} />
      </div>
    </section>
  </div>

  {page.uncertainties.length > 0 && (
    <UncertaintyPanel uncertainties={page.uncertainties} pageNumber={page.page_number} />
  )}

  {showDivider && <div class="page-divider" aria-hidden="true"></div>}
</article>
