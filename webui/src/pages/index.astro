---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import translationData from '../data/translation-data.json';

const { book_title, author, total_chunks, total_pages, total_uncertainties, chunks } = translationData;

// Flatten all pages for the header search index
const allPages = chunks
  .flatMap((chunk) => chunk.pages)
  .sort((a, b) => a.page_number - b.page_number);

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${book_title} — The Dance of the Fool`}>
  <!-- Search data for Header component -->
  <script id="search-data" type="application/json" is:inline set:html={JSON.stringify(allPages.map(p => ({
    page_number: p.page_number,
    ukrainian_text: p.ukrainian_text,
    english_text: p.english_text
  })))} />

  <Header searchData={true} />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-16">
    <!-- Hero -->
    <section class="grid gap-8 md:grid-cols-[minmax(0,260px)_1fr] md:gap-12 items-center mb-6">
      <div class="mx-auto md:mx-0 w-48 sm:w-56 md:w-full">
        <img
          src={`${base}book-cover.png`}
          alt={`Cover of «${book_title}» by ${author}`}
          class="w-full rounded-lg shadow-2xl ring-1 ring-black/10 dark:ring-white/10"
          width="260"
          loading="eager"
        />
      </div>

      <div class="text-center md:text-left">
        <p class="text-sm uppercase tracking-widest text-blue-600 dark:text-blue-400 font-semibold mb-2">
          Unofficial English translation
        </p>
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white leading-tight">
          The Dance of the Fool
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300 mt-2">
          {book_title} · {author}
        </p>

        <p class="text-gray-600 dark:text-gray-400 mt-5 leading-relaxed max-w-prose mx-auto md:mx-0">
          Space biologist Gil — a veteran of many off-world military operations — takes a
          job on a scientific expedition to the distant, strange planet Ix-Chel, hoping it
          will solve all his problems at once. It doesn't.
        </p>

        <!-- Resume slot (populated client-side if the reader has progress) -->
        <div id="resumeSlot" class="hidden mt-6"></div>

        <div class="mt-6 flex flex-wrap gap-3 justify-center md:justify-start">
          <a
            href={`${base}book`}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-semibold shadow-sm transition-colors"
          >
            📖 Start reading
          </a>
          <a
            href="#contents"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 font-medium transition-colors"
          >
            Browse by section
          </a>
        </div>

        <p class="text-sm text-gray-500 dark:text-gray-400 mt-5">
          {total_pages} pages · {total_chunks} sections · English with the Ukrainian original alongside
        </p>
      </div>
    </section>

    <!-- Reading tip -->
    <div class="mb-12 text-center md:text-left text-sm text-gray-500 dark:text-gray-400 max-w-prose mx-auto md:mx-0">
      Tip: use the settings menu (⚙) to switch between <strong>English</strong> and
      <strong>side-by-side Ukrainian</strong>, change text size, or turn on the translator's notes.
    </div>

    <!-- Contents / Browse by section (de-emphasized) -->
    <section id="contents" class="scroll-mt-20">
      <div class="flex items-baseline justify-between mb-5">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">Contents</h2>
        <span class="text-sm text-gray-500 dark:text-gray-400">{total_chunks} sections</span>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {chunks.map((chunk) => (
          <a
            href={`${base}chunk/${String(chunk.chunk_number).padStart(2, '0')}`}
            class="group rounded-lg p-4 border border-gray-200 dark:border-gray-700 bg-white/70 dark:bg-gray-800/60 hover:border-blue-500 dark:hover:border-blue-400 hover:shadow-md transition-all"
          >
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold text-gray-400 dark:text-gray-500">
                {String(chunk.chunk_number).padStart(2, '0')}
              </span>
              {chunk.uncertainty_count > 0 && (
                <span class="uncertainty-badge note-only text-[0.65rem]">
                  {chunk.uncertainty_count}
                </span>
              )}
            </div>
            <div class="mt-1 font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
              Pages {chunk.page_range}
            </div>
          </a>
        ))}
      </div>

      <p class="text-xs text-gray-400 dark:text-gray-500 mt-4">
        Sections are the translation's working units ({total_uncertainties} translator's notes across the book).
        For a continuous read, use <a href={`${base}book`} class="underline hover:text-blue-600 dark:hover:text-blue-400">Start reading</a>.
      </p>
    </section>
  </main>

  <script>
    // Offer "Resume reading" if the reader has progress saved.
    (() => {
      const slot = document.getElementById('resumeSlot');
      if (!slot) return;
      try {
        const raw = localStorage.getItem('lastRead');
        if (!raw) return;
        const { path, page } = JSON.parse(raw);
        if (!path || !page) return;
        const href = `${path}#page-${page}`;
        slot.innerHTML =
          '<a href="' + href + '" class="inline-flex items-center gap-2 text-sm px-4 py-2 rounded-lg border border-blue-300 dark:border-blue-700 bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors">↩ Resume reading — page ' +
          page +
          '</a>';
        slot.classList.remove('hidden');
      } catch (e) {
        /* ignore malformed storage */
      }
    })();
  </script>
</BaseLayout>
