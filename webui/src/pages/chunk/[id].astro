---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import PageSpread from '../../components/PageSpread.astro';
import translationData from '../../data/translation-data.json';

export function getStaticPaths() {
  return translationData.chunks.map((chunk) => ({
    params: { id: String(chunk.chunk_number).padStart(2, '0') },
    props: { chunk },
  }));
}

const { chunk } = Astro.props;
const { chunk_number, page_range, pages, uncertainty_count } = chunk;
const base = import.meta.env.BASE_URL;
const lastPage = pages[pages.length - 1];
const total = translationData.total_chunks;
---

<BaseLayout title={`Chunk ${String(chunk_number).padStart(2, '0')} - ${translationData.book_title}`}>
  <!-- Search data for Header component -->
  <script id="search-data" type="application/json" is:inline set:html={JSON.stringify(pages.map(p => ({
    page_number: p.page_number,
    ukrainian_text: p.ukrainian_text,
    english_text: p.english_text
  })))} />

  <Header currentChunk={chunk_number} searchData={true} />

  <main class="reader-main max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Section header -->
    <div class="mb-8 max-w-[40rem] mx-auto reader-lede">
      <a href={base} class="inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors mb-3">
        ← Contents
      </a>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
        Section {String(chunk_number).padStart(2, '0')}
        <span class="text-gray-400 dark:text-gray-500 font-normal text-lg"> / {total}</span>
      </h1>
      <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm">
        Pages {page_range}
        {uncertainty_count > 0 && (
          <span class="ml-2 uncertainty-badge note-only">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
            {uncertainty_count} translator's notes
          </span>
        )}
      </p>
    </div>

    <!-- Pages -->
    <div class="space-y-10">
      {pages.map((page) => (
        <PageSpread page={page} showDivider={page.page_number !== lastPage.page_number} />
      ))}
    </div>

    <!-- Bottom Navigation -->
    <div class="mt-12 pt-8 border-t border-gray-300 dark:border-gray-700 max-w-[40rem] mx-auto reader-lede">
      <div class="flex items-center justify-between gap-3">
        <a
          href={chunk_number > 1 ? `${base}chunk/${String(chunk_number - 1).padStart(2, '0')}` : '#'}
          class={`px-5 py-3 rounded-lg font-medium transition-colors ${
            chunk_number > 1
              ? 'bg-blue-600 hover:bg-blue-700 text-white'
              : 'bg-gray-100 dark:bg-gray-800 text-gray-400 cursor-not-allowed pointer-events-none'
          }`}
          aria-disabled={chunk_number <= 1}
        >
          ← Prev
        </a>

        <a
          href={base}
          class="px-5 py-3 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 font-medium transition-colors"
        >
          Contents
        </a>

        <a
          href={chunk_number < total ? `${base}chunk/${String(chunk_number + 1).padStart(2, '0')}` : '#'}
          class={`px-5 py-3 rounded-lg font-medium transition-colors ${
            chunk_number < total
              ? 'bg-blue-600 hover:bg-blue-700 text-white'
              : 'bg-gray-100 dark:bg-gray-800 text-gray-400 cursor-not-allowed pointer-events-none'
          }`}
          aria-disabled={chunk_number >= total}
        >
          Next →
        </a>
      </div>
    </div>
  </main>

  <script define:vars={{ total, base }}>
    // Arrow-key navigation between sections
    document.addEventListener('keydown', (e) => {
      const target = e.target;
      if (target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA')) return;

      const chunkNum = parseInt(window.location.pathname.replace(/\/$/, '').split('/').pop() || '0');

      if (e.key === 'ArrowLeft' && chunkNum > 1) {
        window.location.href = `${base}chunk/${String(chunkNum - 1).padStart(2, '0')}`;
      } else if (e.key === 'ArrowRight' && chunkNum < total) {
        window.location.href = `${base}chunk/${String(chunkNum + 1).padStart(2, '0')}`;
      }
    });
  </script>
</BaseLayout>
