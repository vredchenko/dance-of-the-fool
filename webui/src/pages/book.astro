---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import PageSpread from '../components/PageSpread.astro';
import translationData from '../data/translation-data.json';

// Flatten all pages from all chunks into a single array in reading order
const allPages = translationData.chunks
  .flatMap((chunk) => chunk.pages)
  .sort((a, b) => a.page_number - b.page_number);

const base = import.meta.env.BASE_URL;
const lastPage = allPages[allPages.length - 1];
const maxPage = lastPage ? lastPage.page_number : translationData.total_pages;
---

<BaseLayout title={`Read — ${translationData.book_title}`}>
  <!-- Search data for Header component -->
  <script id="search-data" type="application/json" is:inline set:html={JSON.stringify(allPages.map(p => ({
    page_number: p.page_number,
    ukrainian_text: p.ukrainian_text,
    english_text: p.english_text
  })))} />

  <Header searchData={true} />

  <main class="reader-main max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Book header -->
    <div class="mb-8 max-w-[40rem] mx-auto reader-lede">
      <a href={base} class="inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors mb-3">
        ← Contents
      </a>
      <div class="flex items-end justify-between gap-4 flex-wrap">
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
          {translationData.book_title}
        </h1>
        <div class="flex items-center gap-2 text-sm">
          <label for="pageJump" class="text-gray-500 dark:text-gray-400">Jump to page</label>
          <input
            type="number"
            id="pageJump"
            min="1"
            max={maxPage}
            placeholder={`1–${maxPage}`}
            class="w-24 px-2 py-1 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500"
          />
        </div>
      </div>
      <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm">{translationData.author} · continuous reading</p>
    </div>

    <!-- Pages -->
    <div class="space-y-10">
      {allPages.map((page) => (
        <PageSpread page={page} showDivider={page.page_number !== lastPage.page_number} />
      ))}
    </div>

    <!-- Back to top -->
    <div class="mt-12 pt-8 border-t border-gray-300 dark:border-gray-700 max-w-[40rem] mx-auto reader-lede flex justify-center">
      <button
        onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
        class="px-6 py-3 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 font-medium transition-colors"
      >
        ↑ Back to top
      </button>
    </div>
  </main>

  <script define:vars={{ maxPage }}>
    // Track the currently-visible page in the URL hash (for resume + deep links)
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.target.id && history.replaceState) {
            history.replaceState(null, '', `#${entry.target.id}`);
          }
        });
      },
      { threshold: 0.5, rootMargin: '-100px 0px -50% 0px' }
    );
    document.querySelectorAll('[id^="page-"]').forEach((el) => observer.observe(el));

    const jumpTo = (n) => {
      const el = document.getElementById(`page-${n}`);
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };
    const currentPage = () => {
      const h = window.location.hash;
      if (h.startsWith('#page-')) return parseInt(h.replace('#page-', ''));
      return 1;
    };

    document.addEventListener('keydown', (e) => {
      const target = e.target;
      if (target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA')) return;
      if (e.key === 'PageDown') { e.preventDefault(); jumpTo(Math.min(currentPage() + 1, maxPage)); }
      else if (e.key === 'PageUp') { e.preventDefault(); jumpTo(Math.max(currentPage() - 1, 1)); }
      else if (e.key === 'Home' && !e.ctrlKey) { e.preventDefault(); jumpTo(1); }
      else if (e.key === 'End' && !e.ctrlKey) { e.preventDefault(); jumpTo(maxPage); }
    });

    document.getElementById('pageJump')?.addEventListener('keypress', (e) => {
      if (e.key !== 'Enter') return;
      const n = parseInt(e.target.value);
      if (n >= 1 && n <= maxPage) window.location.hash = 'page-' + n;
    });
  </script>
</BaseLayout>
